# =============================================================================
# Environment variables for the smoketest notebook
# =============================================================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# IMPORTANT: .env is in .gitignore — never commit your real keys!
# =============================================================================

# Hugging Face token (required for gated models like Mistral, Gemma)
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# OpenAI API key (required for the final report generation)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
